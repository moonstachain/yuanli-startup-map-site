  "pipeline": {
    "daily": {
      "trigger": "每天 13:00；只处理昨天及更早。",
      "inputs": [
        "Looki cloud moments/files/journals/for_you",
        "NAS 媒体原件与当日复盘",
        "前一日 receipts",
        "本地选题/证据/样片状态"
      ],
      "processing": [
        "同步归档：daily_sync.py 跳过当天、跳过已归档。",
        "素材盘点：按 day/moment/file_type/video_count/source_dir 建 inventory。",
        "生产力语义分类：deep_work、meeting、creation、movement、life_context、admin、unknown。",
        "隐私分级：private_internal、needs_human_review、public_candidate_after_review。",
        "生产力内容评分：work_density 0.28 + evidence_value 0.18 + visual_quality 0.16 + narrative_potential 0.14 + clip_feasibility 0.10 + external_suitability 0.08 + novelty 0.06。",
        "生成每日私人飞书卡片与 receipt；已有 sent receipt 则幂等跳过。"
      ],
      "outputs": [
        "data/looki-inventory.json",
        "feishu/daily-reminder-preview-YYYY-MM-DD.md",
        "feishu/daily-reminder-send-receipt-YYYY-MM-DD.json",
        "evidence/evidence-cards.json",
        "clips/highlight-candidates.json",
        "dashboard telemetry"
      ],
      "acceptance_gate": [
        "also_external=false",
        "receipt_version 存在",
        "当天数据不归档",
        "敏感片段不进公开候选",
        "重复运行不重复发送"
      ]
    },
    "weekly": {
      "trigger": "每周一 09:20；生成上一自然周。",
      "inputs": [
        "7 天 daily inventory",
        "daily receipts",
        "clip topics",
        "sample receipts",
        "evidence cards"
      ],
      "processing": [
        "聚合工作密度、内容产出、场景分布、素材产能、证据资产。",
        "识别生产力模式：高能时段、深度工作块、会议/交流、创造性输出、生活恢复。",
        "生成 Top 12 下周内容选题与 Top 5 原力大脑候选。",
        "输出私人飞书周报 receipt。"
      ],
      "outputs": [
        "weekly/looki-weekly-brief-START_to_END.json",
        "weekly/looki-weekly-brief-START_to_END.md",
        "feishu/weekly-brief-send-receipt-START_to_END.json"
      ],
      "acceptance_gate": [
        "不混入未结束周数据",
        "数字与 JSON 一致",
        "私人发送 receipt 存在",
        "对外发布仍为人工门"
      ]
    },
    "clips": {
      "trigger": "每日可 dry-run；周报后推荐跑一次。",
      "inputs": [
        "highlight-candidates.json",
        "NAS source_dirs",
        "production scoring",
        "privacy labels"
      ],
      "processing": [
        "生成 Top 12 短视频选题：标题、平台、隐私、脚本、分镜、素材目录、建议时长。",
        "对 Top 1 进入 Clip Pro：探测视频、抽帧、镜头评分、生成 dossier、渲染 20-30s 静音样片。",
        "生成剪映/人工精修交接包：plan.json、shots.json、字幕草稿、发布文案草稿。"
      ],
      "outputs": [
        "clips/short-video-topics.json",
        "clips/sample-render-receipts.json",
        "NAS 剪辑成片/auto-samples/*.mp4",
        "work/<date>_<title>/plan.json"
      ],
      "acceptance_gate": [
        "只渲染 Top 1",
        "ffprobe 可播放",
        "20-30 秒",
        "1920x1080 或明确竖屏任务时 1080x1920",
        "不自动对外发送"
      ]
    },
    "yuanli_gate": {
      "trigger": "daily/weekly 后可自动生成候选；写回必须人工授权。",
      "inputs": [
        "evidence-cards.json",
        "weekly brief",
        "clip topics",
        "sample receipts"
      ],
      "processing": [
        "把高价值 moment 转成 evidence asset。",
        "给每张卡建议写回位置：生活证据层、工作流复盘、内容资产、决策证据。",
        "进入 decision console lane：looki-evidence-writeback-preview。",
        "等待授权记录：asset_ids、writeback_target、expires_at、human_approver、rollback_plan_acknowledged。"
      ],
      "outputs": [
        "memory-assets/asset-index.json",
        "memory-assets/yuanli-brain-writeback-candidates.md",
        "CODEX-LLM-WIKI review packet",
        "human-gated action bundle"
      ],
      "acceptance_gate": [
        "authorization_status=not-authorized",
        "无自动核心写回",
        "无 GitHub/NotebookLM/Feishu 外部写入",
        "风险等级明确"
      ]
    },
    "strategy_board": {
      "trigger": "每次 daily/weekly/clips/yuanli-gate 后重建本地看板。",
      "inputs": [
        "pipeline receipts",
        "action-ledger",
        "risk-register",
        "evidence-index",
        "dashboard-data"
      ],
      "processing": [
        "按 L0-L4 架构渲染战略看板。",
        "按 12 维信息密度自评。",
        "把每个阶段的 hard gate、failure fallback、owner、next action 展示在首屏可扫区域。",
        "生成随身智库左侧导航所需 index entry。"
      ],
      "outputs": [
        "strategic-projects/luki-max-content-engine/dashboard.html",
        "zhiku-self-assess/strategy-boards/index.html",
        "zhiku-self-assess/strategy-boards/strategy-board-index.json"
      ],
      "acceptance_gate": [
        "本地 HTML 可打开",
        "JSON 可解析",
        "外部同步 boundary=approval_required",
        "看板不自动执行动作"
      ]
    }
  },
